# ============================================================
# Buffer de mensajes (Redis) — Debounce de WhatsApp/Chatwoot
# ------------------------------------------------------------
# Cuando el usuario envía varios mensajes seguidos ("hola",
# "todo bien?", "tengo una consulta"), el agente NO debe responder
# a cada uno por separado. Los mensajes se acumulan en Redis durante
# una ventana corta, luego se concatenan y entran al agente como un
# único mensaje para generar UNA sola respuesta.
# ============================================================

# Conexión a Redis — opción A: URL única (recomendada con Redis
# gestionado tipo Upstash / Redis Cloud; usa rediss:// si es con TLS)
#REDIS_URL=redis://localhost:6379/0

# Conexión a Redis — opción B: variables granulares
# (se usan solo si REDIS_URL está vacío)
REDIS_HOST=
REDIS_PORT=
REDIS_DB=0
REDIS_PASSWORD=kkkkkkkkkkkkkkkkkk
# TLS: ponlo en true solo si tu base de Redis tiene activado el cifrado (rediss://)
REDIS_TLS=false

# Activar/desactivar el buffer de mensajes (si es false, el agente
# responde mensaje por mensaje como antes)
MESSAGE_BUFFER_ENABLED=true

# Ventana de espera (segundos): tiempo sin nuevos mensajes del usuario
# antes de concatenar el buffer y disparar la respuesta del agente.
MESSAGE_BUFFER_WINDOW_SECONDS=15

# TTL (segundos) de la clave del buffer en Redis. Evita fugas si una
# conversación queda a medias; debe ser mayor que la ventana de espera.
MESSAGE_BUFFER_TTL_SECONDS=300

# Separador usado al concatenar los mensajes acumulados antes de
# enviarlos al agente (\n = un mensaje por línea).
MESSAGE_BUFFER_SEPARATOR="\n"
